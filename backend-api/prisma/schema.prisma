// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  phone            String
  password         String
  role             Role              @default(CUSTOMER)
  totalPoints      Int               @default(0)
  isMember         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  addresses        Address[]
  priceHistories   PriceHistory[]
  stockIns         StockIn[]
  stockAdjustments StockAdjustment[]
  orders           Order[]           @relation("UserOrders")
  confirmedCod     Order[]           @relation("CodConfirmer")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int
  label       String
  fullAddress String
  kecamatan   String
  city        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([userId])
}

enum Grade {
  BESAR
  SEDANG
  KECIL
}

enum Unit {
  KG
  TRAY
  PETI
}

model Product {
  id          Int              @id @default(autoincrement())
  categoryId  Int
  name        String
  description String?          @db.Text
  imageUrl    String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]

  @@index([categoryId])
  @@index([isActive])
  @@index([categoryId, isActive])
}

model ProductVariant {
  id                 Int               @id @default(autoincrement())
  productId          Int
  grade              Grade
  pricePerKg         Decimal           @db.Decimal(10, 2)
  stockKg            Decimal           @default(0) @db.Decimal(10, 2)
  lowStockThreshold  Decimal           @default(10) @db.Decimal(10, 2)
  lastPriceUpdateAt  DateTime?
  priceHistories     PriceHistory[]
  stockIns           StockIn[]
  stockAdjustments   StockAdjustment[]
  orderItems         OrderItem[]

  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, grade])
  @@index([productId])
  @@index([stockKg])
}

model UnitConversion {
  id           Int     @id @default(autoincrement())
  unit         Unit    @unique
  kgEquivalent Decimal @db.Decimal(10, 3)
}

model PriceHistory {
  id               Int            @id @default(autoincrement())
  productVariantId Int
  oldPrice         Decimal        @db.Decimal(10, 2)
  newPrice         Decimal        @db.Decimal(10, 2)
  changedBy        Int
  changedAt        DateTime       @default(now())

  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [changedBy], references: [id])

  @@index([productVariantId])
  @@index([changedAt])
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String
  address   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stockIns  StockIn[]
}

model StockIn {
  id               Int            @id @default(autoincrement())
  supplierId       Int
  productVariantId Int
  quantityKg       Decimal        @db.Decimal(10, 2)
  pricePerKg       Decimal        @db.Decimal(10, 2)
  totalCost        Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())
  createdBy        Int

  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
  user             User           @relation(fields: [createdBy], references: [id])

  @@index([productVariantId])
  @@index([supplierId])
  @@index([createdAt])
}

model StockAdjustment {
  id               Int            @id @default(autoincrement())
  productVariantId Int
  changeKg         Decimal        @db.Decimal(10, 2)
  reason           String
  adjustedBy       Int
  createdAt        DateTime       @default(now())

  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [adjustedBy], references: [id])

  @@index([productVariantId])
  @@index([createdAt])
}

model ServiceArea {
  id        Int      @id @default(autoincrement())
  city      String
  kecamatan String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([isActive])
  @@index([city, kecamatan])
}

model MembershipConfig {
  id                       Int     @id @default(1)
  pointsPerRupiah          Decimal @db.Decimal(10, 6)
  pointsThresholdForMember Int
  memberDiscountPercent    Decimal @db.Decimal(5, 2)
  minimumOrderKg           Decimal @db.Decimal(10, 2)
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  EXPIRED
  FAILED
}

enum PaymentType {
  MIDTRANS
  COD
}

model Order {
  id                    Int             @id @default(autoincrement())
  orderNumber           String          @unique
  userId                Int
  addressId             Int
  status                OrderStatus     @default(PENDING)
  totalWeightKg         Decimal         @db.Decimal(10, 2)
  subtotalAmount        Decimal         @db.Decimal(10, 2)
  discountAmount        Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount           Decimal         @db.Decimal(10, 2)
  paymentStatus         PaymentStatus   @default(UNPAID)
  paymentType           PaymentType
  midtransOrderId       String?
  midtransTransactionId String?
  paymentChannel        String?
  codConfirmedBy        Int?
  codConfirmedAt        DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation("UserOrders", fields: [userId], references: [id])
  codConfirmer          User?           @relation("CodConfirmer", fields: [codConfirmedBy], references: [id])
  address               Address         @relation(fields: [addressId], references: [id])
  items                 OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([userId, status])
}

model OrderItem {
  id                 Int            @id @default(autoincrement())
  orderId            Int
  productVariantId   Int
  unit               Unit
  quantity           Decimal        @db.Decimal(10, 2)
  weightKgEquivalent Decimal        @db.Decimal(10, 2)
  pricePerKg         Decimal        @db.Decimal(10, 2)
  subtotal           Decimal        @db.Decimal(10, 2)

  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant            ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
}
